# build artifacts
build/
*.obj
*.exe
*.lib
*.exp
*.pdb

# WASM build outputs (generated by build_wasm_othello.sh from the .cpp + a net)
wasmdist/*.js
wasmdist/*.wasm
wasmdist/net.bin

# training logs and rolling checkpoints
*.log
*.latest

# trained weights / checkpoints (ignore by default, but keep released weights)
*.bin
!best6.bin
!best8.bin

# python
__pycache__/
*.pyc
*.pkl

# editor / tool
.vs/
.claude/
*.user
